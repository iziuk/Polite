{
  "name": "polite",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22.22.1",
    "yarn": ">=4.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace polite-mvp dev",
    "dev:mobile": "yarn workspace polite-mobile dev",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint . --max-warnings=0",
    "test": "yarn test:web && yarn test:mobile",
    "test:coverage": "yarn test:web:coverage && yarn test:mobile:coverage",
    "test:e2e": "yarn test:e2e:web && yarn test:e2e:mobile",
    "test:e2e:mobile": "maestro test apps/mobile/.maestro",
    "test:e2e:web": "playwright test",
    "test:mobile": "yarn workspace polite-mobile test",
    "test:mobile:coverage": "yarn workspace polite-mobile test:coverage",
    "test:web": "vitest run",
    "test:web:coverage": "vitest run --coverage",
    "typecheck": "yarn typecheck:web && yarn typecheck:mobile && yarn typecheck:shared",
    "typecheck:web": "yarn workspace polite-mvp typecheck",
    "typecheck:mobile": "yarn workspace polite-mobile typecheck",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "knowledge:index": "node .ai/tools/project-knowledge/index.mjs",
    "knowledge:search": "node .ai/tools/project-knowledge/search.mjs",
    "knowledge:evaluate": "node .ai/tools/project-knowledge/evaluate.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.85.3",
    "react-test-renderer": "^19.2.7",
    "test-renderer": "^1.2.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
