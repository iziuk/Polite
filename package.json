{
  "name": "polite",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.22.1",
    "npm": ">=11.16.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && next dev",
    "dev:mobile": "cd apps/mobile && expo start",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck:web && npm run typecheck:mobile && npm run typecheck:shared",
    "typecheck:web": "npm run typecheck --workspace polite-mvp",
    "typecheck:mobile": "npm run typecheck --workspace polite-mobile",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "knowledge:index": "node .ai/tools/project-knowledge/index.mjs",
    "knowledge:search": "node .ai/tools/project-knowledge/search.mjs",
    "knowledge:evaluate": "node .ai/tools/project-knowledge/evaluate.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
